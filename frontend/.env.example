# Адрес backend-API карьерного консультанта. Скопируйте в .env при необходимости.
#
# Пусто  -> запросы идут на /api (прокси Vite в dev или reverse-proxy портала на проде).
#           Это рекомендуемый вариант: адрес бэкенда скрыт за прокси портала.
# Либо укажите полный адрес ядра напрямую, например: http://127.0.0.1:8080
VITE_API_BASE=
