# ───────────────────────────────────────────────────────────────────────────
# Конфигурация бэкенда карьерного ИИ-консультанта.
# Скопируйте в backend/.env и подставьте реальные адреса внутри сети вуза.
# Ничего не хардкодим в коде — все адреса и токены только здесь.
# ───────────────────────────────────────────────────────────────────────────

# ── LLM для русского и английского (Qwen3-14B через OVMS, OpenAI-совместимый API) ──
LLM_BASE_URL=http://ovms.internal:8000/v3
LLM_MODEL=Qwen3-14B
LLM_API_KEY=not-needed

# ── LLM для казахского (KazLLM-8B / Sherkala-8B, OpenAI-совместимый API) ──
KAZ_BASE_URL=http://kazllm.internal:8000/v1
KAZ_MODEL=KazLLM-8B
KAZ_API_KEY=not-needed

# ── Эмбеддинги (BGE-M3, мультиязычная, OpenAI-совместимый /embeddings) ──
EMBED_BASE_URL=http://embeddings.internal:8000/v1
EMBED_MODEL=bge-m3
EMBED_API_KEY=not-needed
EMBED_DIM=1024

# ── Векторная БД (Postgres + pgvector) ──
# Если оставить пустым — включится локальный JSON-индекс (для разработки/демо
# без Postgres). Для продакшна укажите строку подключения.
DATABASE_URL=postgresql://career:career@localhost:5432/career_advisor
DB_TABLE=kb_chunks

# ── Параметры RAG (можно не менять) ──
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=5

# ── Безопасность ──
# Токен для защиты пересборки индекса (POST /admin/ingest, заголовок X-Admin-Token).
ADMIN_TOKEN=change-me-please
# Домены, которым разрешён доступ из браузера (через запятую).
CORS_ORIGINS=https://ai.knus.edu.kz,http://localhost:5173
